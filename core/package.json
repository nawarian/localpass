{
  "name": "@localpass/core",
  "version": "1.0.0",
  "description": "Shared core library for LocalPass: cryptography, vault, and S3 client",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./config": "./dist/config.js",
    "./crypto": "./dist/crypto.js",
    "./s3": "./dist/s3.js",
    "./store": "./dist/store.js",
    "./vault": "./dist/vault.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@aws-sdk/client-s3": "^3.800.0",
    "@noble/hashes": "^1.7.1"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
